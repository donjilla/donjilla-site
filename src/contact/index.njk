---
layout: base.njk
title: "Contact — Don Jilla Photography"
description: "Contact Don Jilla for editorial commissions, gallery inquiries, licensing, and press kit requests. Pittsburgh, PA based concert and event photographer."
bodyClass: "page-contact"
---

{% block content %}
<div class="contact-page">
  <div class="contact-header">
    <h1>Contact</h1>
    <p>Editorial commissions, gallery inquiries, licensing, and print sales.<br>
    Or reach out directly: <a href="mailto:doctorjilla@icloud.com">doctorjilla@icloud.com</a></p>
  </div>

  <form name="contact" class="contact-form" netlify netlify-honeypot="bot-field" data-netlify="true" action="/contact/success/">
    <input type="hidden" name="form-name" value="contact">
    <p class="hidden"><label>Don't fill this out: <input name="bot-field"></label></p>
    <div class="form-row">
      <div class="form-field">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" placeholder="Your name" required>
      </div>
      <div class="form-field">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="your@email.com" required>
      </div>
    </div>
    <div class="form-row">
      <div class="form-field">
        <label for="org">Organization / Publication</label>
        <input type="text" id="org" name="organization" placeholder="Optional">
      </div>
      <div class="form-field">
        <label for="inquiry">Inquiry Type</label>
        <select id="inquiry" name="inquiry">
          <option value="">Select...</option>
          <option value="editorial">Editorial Commission</option>
          <option value="gallery">Gallery / Exhibition</option>
          <option value="licensing">Licensing / Syndication</option>
          <option value="press">Press Kit Request</option>
          <option value="print">Print Inquiry</option>
          <option value="other">Other</option>
        </select>
      </div>
    </div>
    <div class="form-field">
      <label for="message">Message</label>
      <textarea id="message" name="message" placeholder="Tell me about your project or inquiry..." required></textarea>
    </div>
    <div class="form-submit">
      <button type="submit" class="btn btn-primary">Send Message ↗</button>
    </div>
  </form>

  <!-- Mailing List -->
  <div class="mailing-list-section">
    <div class="mailing-list-inner">
      <p class="label-mono">Stay in the loop</p>
      <h2>New work. First look.</h2>
      <p>Get notified when new albums drop — concerts, festivals, events. No spam, unsubscribe any time.</p>
      <!-- MAILCHIMP: Replace the form action URL below with your Mailchimp embed URL -->
      <!-- Instructions: mailchimp.com → Audience → Signup Forms → Embedded Forms → copy the action URL -->
      <form name="newsletter" class="newsletter-form" netlify netlify-honeypot="bot-field" data-netlify="true">
        <input type="hidden" name="form-name" value="newsletter">
        <p class="hidden"><label>Don't fill this out: <input name="bot-field"></label></p>
        <div class="notify-row">
          <input type="email" name="email" placeholder="your@email.com" required>
          <button type="submit" class="btn btn-primary">Subscribe ↗</button>
        </div>
      </form>
    </div>
  </div>
</div>
{% endblock %}
